{
  "name": "src",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-manifest.js && tsc -b && vite build",
    "lint": "eslint . && stylelint \"src/**/*.css\" && npm run check:literals",
    "lint:css": "stylelint \"src/**/*.css\"",
    "check:literals": "node scripts/check-runtime-literals.js",
    "check:literals:with-size": "node scripts/check-runtime-literals.js --with-size",
    "preview": "vite preview",
    "test": "vitest run",
    "sonar:scan": "vitest run --coverage && dotenv -e .env -- sonar-scanner",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "stylelint": "^17.6.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
